# 갓생맵 환경변수. 실제 값은 .env(gitignore됨)나 Vercel 프로젝트 설정에 둔다.
# NEXT_PUBLIC_ 접두사는 브라우저 번들에 그대로 실린다 — 비밀은 절대 붙이지 말 것.

# ── 데이터베이스 ──────────────────────────────────────────────────────────────
# 로컬 개발: Docker 불필요 — 직접 띄운 Postgres 17.
DATABASE_URL=postgres://postgres@localhost:5433/jumsim
#
# 배포(Vercel + Supabase):
#   ⚠️ 런타임 DATABASE_URL은 반드시 Supabase "Transaction 풀러"를 쓴다 (Connect → Transaction).
#      호스트에 'pooler', 포트 6543. 서버리스가 직접 연결(5432)하면 커넥션이 폭발한다.
#      db.ts가 'pooler'/':6543'을 감지해 prepare:false로 자동 설정한다.
#   예: DATABASE_URL=postgres://postgres.[프로젝트]:[비번]@aws-0-[리전].pooler.supabase.com:6543/postgres
#   마이그레이션(scripts/migrate.mjs)만 "직접 연결"(5432, db.[프로젝트].supabase.co)로 돌린다.
#   (PostGIS 같은 확장에 의존하지 않으므로 스키마·쿼리는 그대로 돈다.)

# ── OpenAI ───────────────────────────────────────────────────────────────────
# 메뉴 아이콘 생성 + 텍스트 검열(기본 gpt-4.1-nano)에 쓴다. 배포 런타임에 필요.
OPENAI_API_KEY=
# 검열 AI 스위치 — 키가 있으면 기본 ON. 끄려면 off. 모델은 기본 gpt-4.1-nano.
# MODERATION_AI=off
# MODERATION_AI_MODEL=gpt-4.1-nano

# ── 정책 ─────────────────────────────────────────────────────────────────────
# 기여 표시 정책. optimistic(기본): 깨끗한 리뷰 즉시 노출 / gated: 승인 전 숨김.
# 포인트는 어느 쪽이든 항상 운영자 확인 후 지급된다.
# MODERATION_MODE=gated

# ── /admin 잠금 ──────────────────────────────────────────────────────────────
# 배포 전 반드시 새로 발급할 것 (이 채팅에 노출된 값 쓰지 말 것). 예: openssl rand -base64 32
ADMIN_PASSWORD=
ADMIN_SECRET=

# ── 데이터 적재(ingest) 전용 ─────────────────────────────────────────────────
# 서울시 공공데이터 API 키. 가게 뼈대를 서울 전역에 깔 때 scripts/ingest-*.mjs가 쓴다.
# 발급: https://data.seoul.go.kr → 로그인 → Open API → 인증키 신청 (무료, 즉시)
# 배포 런타임엔 불필요.
SEOUL_API_KEY=

# 지도 타일. 비워두면 OpenFreeMap Positron(무료·상업 가능·키 불필요)을 쓴다.
NEXT_PUBLIC_VWORLD_KEY=
