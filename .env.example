# 로컬 개발 (Docker 불필요 — 직접 띄운 Postgres 17)
DATABASE_URL=postgres://postgres@localhost:5433/jumsim

# 서울시 공공데이터 API 키. 가게 뼈대를 서울 전역에 깔 때 필요하다.
# 발급: https://data.seoul.go.kr → 로그인 → Open API → 인증키 신청 (무료, 즉시)
# 'sample'로도 시험은 되지만 5건만 돌아온다.
SEOUL_API_KEY=

# 지도 타일. 비워두면 OSM 공식 타일을 쓴다 (로컬/소규모 테스트용).
# 실서비스로 키울 땐 VWorld로 갈아타야 한다 — OSM 정책상 상업 서비스는 차단될 수 있다.
# 발급: https://www.vworld.kr/dev/v4api.do (무료, 도메인 등록 필요)
NEXT_PUBLIC_VWORLD_KEY=

# ── 나중에 Supabase로 옮길 때 ──────────────────────────
# DATABASE_URL을 Supabase 커넥션 문자열로 바꾸면 스키마와 쿼리는 그대로 돈다.
# (PostGIS 같은 확장에 의존하지 않도록 짜두었다)
# DATABASE_URL=postgres://postgres:[비밀번호]@db.[프로젝트].supabase.co:5432/postgres
